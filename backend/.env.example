# Environment Configuration – CAMI Netherlands Backend
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_ENV=development
PORT=5000

# ── Email – Resend.com ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here

# ── Admin Dashboard ────────────────────────────────────────────────────────────
ADMIN_EMAIL=info@centrocami.it
ADMIN_PASSWORD=change_me_before_deploy

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Program Calendar ───────────────────────────────────────────────────────────
# First day of the next cohort (YYYY-MM-DD). Leave blank = auto (2 Saturdays from now).
PROGRAM_START_DATE=2026-07-05
PROGRAM_SESSION_HOUR=10
PROGRAM_SESSION_DURATION=4
PROGRAM_LOCATION=Utrecht, Netherlands

# Environment Configuration – CAMI Netherlands Backend
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_ENV=development
PORT=5000

# ── Email – Resend.com ─────────────────────────────────────────────────────────
# Sign up free at https://resend.com → API Keys → Create key
# Free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=re_your_key_here

# ── Admin Dashboard ────────────────────────────────────────────────────────────
ADMIN_EMAIL=info@centrocami.it
ADMIN_PASSWORD=change_me_before_deploy

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
